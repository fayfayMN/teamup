# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit it.
#
# How to get these values: see the "Google Sheets setup" section in README.md.

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit"
type        = "service_account"

# Paste everything inside the { } from your service account JSON key file.
private_key_id  = "abc123..."
private_key     = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email    = "teamup@your-project.iam.gserviceaccount.com"
client_id       = "123456789"
token_uri       = "https://oauth2.googleapis.com/token"
